# ========================================
# 🌍 ARTISANNOW - CONFIGURATION ENVIRONNEMENT
# ========================================
# ⚠️ NE JAMAIS COMMITTER CE FICHIER AVEC DE VRAIES CLÉS
# Copier ce fichier en .env et remplir avec vos vraies valeurs

# ========================================
# 🗺️ GOOGLE MAPS & GEOLOCATION
# ========================================
# Créer un projet sur https://console.cloud.google.com
# Activer les APIs suivantes :
#   - Maps JavaScript API
#   - Geocoding API
#   - Places API
#   - Directions API
#   - Distance Matrix API
# Restreindre la clé par domaine (artisannow.app, *.artisannow.app)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# ========================================
# 💳 STRIPE PAYMENTS
# ========================================
# Créer un compte sur https://dashboard.stripe.com
# Mode TEST pour développement, mode LIVE pour production
# Clé publique (côté client, safe to expose)
STRIPE_PUBLIC_KEY=pk_test_YOUR_STRIPE_PUBLIC_KEY_HERE
# Clé secrète (côté serveur, NEVER expose)
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
# Webhook secret (pour vérifier les événements Stripe)
# Configurer webhook sur : https://api.artisannow.app/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE
# Commission ArtisanNow (15% = 0.15)
COMMISSION_PERCENTAGE=0.15

# ========================================
# 🔐 SUPABASE (DATABASE & AUTH)
# ========================================
# Créer un projet sur https://app.supabase.com
# Copier URL et clés depuis Project Settings > API
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ========================================
# 🔥 FIREBASE (ALTERNATIVE OU COMPLÉMENT)
# ========================================
# Créer un projet sur https://console.firebase.google.com
# Activer Authentication (Email/Password + Google)
# Activer Cloud Storage pour photos/documents
# Activer Cloud Messaging pour notifications
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_PROJECT_ID=artisannow
FIREBASE_AUTH_DOMAIN=artisannow.firebaseapp.com
FIREBASE_DATABASE_URL=https://artisannow.firebaseio.com
FIREBASE_STORAGE_BUCKET=artisannow.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
FIREBASE_APP_ID=your_firebase_app_id_here
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ========================================
# 📱 PUSH NOTIFICATIONS (EXPO)
# ========================================
# Configurer sur https://expo.dev/accounts/[account]/settings/access-tokens
# Ou utiliser Firebase Cloud Messaging (FCM)
EXPO_PUSH_TOKEN=your_expo_push_token_here
EXPO_PROJECT_ID=your_expo_project_id_here
# Firebase Cloud Messaging (si utilisé)
FCM_SERVER_KEY=your_fcm_server_key_here

# ========================================
# 🤖 INTELLIGENCE ARTIFICIELLE
# ========================================
# OpenAI (GPT-4 pour chat assistant, DALL-E pour images)
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY_HERE
# Google Cloud Vision (pour analyse d'images)
GOOGLE_CLOUD_VISION_API_KEY=YOUR_VISION_API_KEY_HERE
# Speech-to-Text / Text-to-Speech
GOOGLE_CLOUD_SPEECH_API_KEY=YOUR_SPEECH_API_KEY_HERE
# Alternative : Azure Cognitive Services
AZURE_COGNITIVE_KEY=YOUR_AZURE_KEY_HERE
AZURE_COGNITIVE_ENDPOINT=https://YOUR_REGION.api.cognitive.microsoft.com/

# ========================================
# 📧 EMAIL SERVICE (NOTIFICATIONS & INVOICES)
# ========================================
# SendGrid, Mailgun, AWS SES, ou Resend
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY_HERE
EMAIL_FROM=noreply@artisannow.app
EMAIL_FROM_NAME=ArtisanNow
# Alternative : Resend (recommandé)
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE

# ========================================
# 📲 SMS NOTIFICATIONS (TWILIO)
# ========================================
# Créer un compte sur https://www.twilio.com
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+33XXXXXXXXX

# ========================================
# 🌐 APPLICATION URLs
# ========================================
# Environnement (development, staging, production)
NODE_ENV=production
# URL de l'application principale
APP_URL=https://artisannow.app
# URL du frontend web
FRONTEND_URL=https://app.artisannow.app
# URL de l'API backend
API_URL=https://api.artisannow.app
# Deep linking (pour l'app mobile)
DEEP_LINK_SCHEME=artisannow://

# ========================================
# 🔒 SÉCURITÉ & ENCRYPTION
# ========================================
# Clé secrète pour JWT (générer avec: openssl rand -hex 32)
JWT_SECRET=YOUR_RANDOM_32_CHAR_SECRET_KEY_HERE
# Salt pour encryption (générer avec: openssl rand -hex 16)
ENCRYPTION_SALT=YOUR_ENCRYPTION_SALT_HERE
# Session secret
SESSION_SECRET=YOUR_SESSION_SECRET_HERE

# ========================================
# 📊 ANALYTICS & MONITORING
# ========================================
# Google Analytics
GA_TRACKING_ID=G-XXXXXXXXXX
# Mixpanel
MIXPANEL_TOKEN=YOUR_MIXPANEL_TOKEN
# Sentry (error tracking)
SENTRY_DSN=https://YOUR_SENTRY_DSN@sentry.io/PROJECT_ID
SENTRY_AUTH_TOKEN=YOUR_SENTRY_AUTH_TOKEN
# Amplitude (user analytics)
AMPLITUDE_API_KEY=YOUR_AMPLITUDE_API_KEY

# ========================================
# 💼 BUSINESS & COMPLIANCE
# ========================================
# TVA (20% en France = 0.20)
VAT_RATE=0.20
# Numéro SIRET (entreprise française)
COMPANY_SIRET=YOUR_SIRET_NUMBER
# Support contact
SUPPORT_EMAIL=support@artisannow.app
SUPPORT_PHONE=+33XXXXXXXXX

# ========================================
# 🧪 TESTING & DEVELOPMENT
# ========================================
# Désactiver certaines vérifications en dev
SKIP_EMAIL_VERIFICATION=false
SKIP_PAYMENT_VERIFICATION=false
# Mode sandbox pour Stripe
USE_STRIPE_TEST_MODE=true
# Logs détaillés
DEBUG_MODE=false
LOG_LEVEL=info

# ========================================
# ☁️ CLOUD STORAGE (AWS S3 / GOOGLE CLOUD)
# ========================================
# AWS S3 pour stocker photos, documents, factures
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_REGION=eu-west-3
AWS_S3_BUCKET=artisannow-uploads
# Alternative : Google Cloud Storage
GCS_PROJECT_ID=artisannow
GCS_BUCKET_NAME=artisannow-storage
GCS_KEYFILE_PATH=./gcs-keyfile.json

# ========================================
# 🔗 WEBHOOKS & INTEGRATIONS
# ========================================
# Webhook pour notifications externes
WEBHOOK_URL=https://api.artisannow.app/webhooks
# Slack notifications (optionnel)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ========================================
# 🌍 LOCALIZATION
# ========================================
# Langue par défaut
DEFAULT_LANGUAGE=fr
# Devises supportées
SUPPORTED_CURRENCIES=EUR,USD,GBP
DEFAULT_CURRENCY=EUR
# Timezone
DEFAULT_TIMEZONE=Europe/Paris

# ========================================
# 🚀 EXPO CONFIGURATION
# ========================================
# URL publique du Toolkit Rork (pour l'IA intégrée)
EXPO_PUBLIC_TOOLKIT_URL=https://toolkit.rork.com
# Expo project ID (depuis app.json)
EXPO_PUBLIC_PROJECT_ID=your_expo_project_id_here
